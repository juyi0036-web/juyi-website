# JUYI CHR 环境变量配置
# 复制此文件为 .env 并填写实际值

# 网站配置
NEXT_PUBLIC_SITE_URL=https://www.juyi-chr.com
NEXT_PUBLIC_SITE_NAME=JUYI CHR

# 邮件服务器配置 (SMTP)
# 推荐使用Gmail SMTP或专业邮件服务
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 邮箱地址
EMAIL_FROM=contact@juyi-chr.com
EMAIL_TO=contact@juyi-chr.com

# Google Analytics (可选)
NEXT_PUBLIC_GA_ID=

# SEO配置
NEXT_PUBLIC_DEFAULT_TITLE=JUYI CHR | Supply Chain Partner
NEXT_PUBLIC_DEFAULT_DESCRIPTION=Votre partenaire supply chain en Chine pour équipements CHR et boulangerie premium

# 客户数据存储
CUSTOMER_DATA_PATH=./data/customers.json

# 汇报配置
REPORT_TIME=09:00
REPORT_EMAIL=your-email@example.com